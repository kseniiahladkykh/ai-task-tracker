generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id        String    @id @default(cuid())
  rawInput  String
  title     String
  priority  String
  deadline  DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
}
